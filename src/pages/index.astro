---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout>
  <h1>I write words that make people act.</h1>

  <p>
    Freelance copywriter helping brands turn attention into clear, persuasive messaging that converts.
  </p>

  <!-- HIRE ME SECTION -->
<div style="margin-top:60px; padding:20px; border:1px solid #1f1f1f; border-radius:10px;">
  <h2 style="font-size:22px; margin-bottom:10px;">Work with me</h2>

  <p style="font-size:16px; color:#b3b3b3;">
    If you need clear, conversion-focused copy for your website, landing page, or emails, I can help.
  </p>

  <p style="font-size:16px; color:#b3b3b3; margin-top:15px;">
    You can reach me at:
  </p>

  <!-- EMAIL TEXT -->
  <p style="font-size:16px; color:white; font-weight:500; margin-top:5px;">
    chrisrichelong@gmail.com
  </p>

  <!-- BUTTON -->
  <a
    href="mailto:chrisrichelong@gmail.com"
    style="
      display:inline-block;
      margin-top:15px;
      padding:10px 14px;
      background:white;
      color:black;
      text-decoration:none;
      border-radius:6px;
      font-size:14px;
      font-weight:500;
    "
  >
    Email me
  </a>
</div>
</MainLayout>