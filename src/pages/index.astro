<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Conference Documentation & Rapporteur Services</title>

  <style>
  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
    color: #111;
    background: #fff;
    line-height: 1.65;
  }

  main {
    max-width: 980px;
    margin: 0 auto;
  }

  /* TYPOGRAPHY (report-like hierarchy) */
  h1 {
    font-size: clamp(30px, 4.5vw, 52px);
    line-height: 1.15;
    margin: 0 0 14px 0;
    letter-spacing: -0.02em;
  }

  h2 {
    font-size: clamp(20px, 3vw, 32px);
    margin: 0 0 10px 0;
    letter-spacing: -0.01em;
  }

  h3 {
    font-size: 17px;
    margin: 0 0 6px 0;
  }

  p {
    font-size: clamp(15px, 2vw, 18px);
    color: #444;
    margin: 0 0 10px 0;
  }

  ul {
    margin: 0 0 14px 0;
    padding-left: 18px;
  }

  li {
    margin-bottom: 5px;
    color: #444;
  }

  /* REPORT-STYLE SPACING SYSTEM */
  section {
    padding: 28px 24px;
  }

  section:last-of-type {
  padding-bottom: 64px;
}

  /* slightly tighter spacing between blocks inside sections */
  .block {
    margin-bottom: 14px;
  }

  /* HEADER (kept simple + institutional) */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 56px;
    border-bottom: 1px solid #e5e5e5;
    flex-wrap: wrap;
    gap: 14px;
  }

  nav {
    display: flex;
    gap: 18px;
    flex: 1;
    justify-content: center;
    flex-wrap: wrap;
  }

  nav a {
    color: #111;
    font-size: 14px;
  }

  nav a.active {
    color: #16a34a;
    font-weight: 600;
  }

  .btn {
    background: #16a34a;
    color: #fff;
    padding: 10px 16px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 14px;
    white-space: nowrap;
  }

  /* GRID (slightly tighter) */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 12px;
  }

  .card {
    border: 1px solid #e5e5e5;
    padding: 16px;
    border-radius: 12px;
  }

  /* MOBILE */
  @media (max-width: 768px) {
    header {
      flex-direction: column;
      text-align: center;
      padding: 16px 18px;
    }

    nav {
      justify-content: center;
    }

    section {
      padding: 24px 18px;
    }

    .btn {
      width: 100%;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    section {
      padding: 22px 16px;
    }

    nav {
      gap: 10px;
    }
  }
</style>
</head>

