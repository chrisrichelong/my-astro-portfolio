---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Chris | Copywriter</title>

    <!-- Simple clean font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
      body {
        margin: 0;
        font-family: Inter, system-ui, sans-serif;
        background: #0b0b0f;
        color: #e5e5e5;
        line-height: 1.6;
      }

      a {
        color: #cfcfcf;
        text-decoration: none;
        font-size: 14px;
      }

      a:hover {
        color: white;
      }

      header {
        display: flex;
        justify-content: space-between;
        padding: 24px 40px;
        border-bottom: 1px solid #1f1f1f;
      }

      nav {
        display: flex;
        gap: 18px;
      }

      main {
        max-width: 780px;
        margin: 80px auto;
        padding: 0 24px;
      }

      h1 {
        font-size: 44px;
        line-height: 1.2;
        letter-spacing: -0.02em;
        margin-bottom: 16px;
      }

      p {
        color: #b3b3b3;
        font-size: 18px;
      }
    </style>
  </head>

  <body>

    <header>
      <div style="font-weight:600;">Chris Richel Ong</div>

      <nav>
        <a href="/">Home</a>
        <a href="/work">Writing</a>
        <a href="/about">About</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

  </body>
</html>