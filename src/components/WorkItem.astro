---
const { image, title, description } = Astro.props;
---

<div style="
  display:grid;
  grid-template-columns:1fr;
  gap:12px;
  margin-bottom:30px;
">

  <img
    src={image}
    alt={title}
    style="width:100%; border-radius:12px; border:1px solid #eee;"
  />

  <div>
    <h3 style="font-size:18px; margin-bottom:6px;">
      {title}
    </h3>

    <p style="color:#555; line-height:1.6; margin:0;">
      {description}
    </p>
  </div>

</div>